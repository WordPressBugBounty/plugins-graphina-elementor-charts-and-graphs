{
	"name": "@iqonic/vite-for-wp",
	"version": "0.12.0",
	"description": "Vite integration for WordPress plugins and themes development.",
	"author": "Dzikri Aziz",
	"packageManager": "pnpm@10.12.3",
	"type": "module",
	"types": "types/index.d.ts",
	"homepage": "https://gitlab.com/gmits/wp_plugins/vite-for-wp",
	"repository": {
		"type": "git",
		"url": "https://gitlab.com/gmits/wp_plugins/vite-for-wp.git"
	},
	"bugs": {
		"url": "https://gitlab.com/gmits/wp_plugins/vite-for-wp/-/issues"
	},
	"keywords": [
		"vite",
		"wordpress"
	],
	"devDependencies": {
		"@changesets/cli": "^2.29.5",
		"@eslint/js": "^9.29.0",
		"@iqonic/eslint-config": "file:../iqonic-eslint-config",
		"@types/eslint": "^9.6.1",
		"@types/node": "^24.0.4",
		"dts-buddy": "^0.6.2",
		"eslint": "^9.29.0",
		"globals": "^16.2.0",
		"rollup-plugin-external-globals": "^0.13.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.35.0",
		"vite": "^7.0.0",
		"vite-plugin-external": "^6.2.2"
	},
	"peerDependencies": {
		"rollup-plugin-external-globals": "^0.13.0",
		"vite": "^7.0.0",
		"vite-plugin-external": "^6.2.2"
	},
	"peerDependenciesMeta": {
		"rollup-plugin-external-globals": {
			"optional": true
		},
		"vite-plugin-external": {
			"optional": true
		}
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./types/index.d.ts",
			"import": "./src/exports/index.js"
		},
		"./plugins": {
			"types": "./types/index.d.ts",
			"import": "./src/exports/plugins/index.js"
		},
		"./utils": {
			"types": "./types/index.d.ts",
			"import": "./src/exports/utils/index.js"
		}
	},
	"files": [
		"src",
		"types"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"check": "tsc --noEmit",
		"eslint": "eslint .",
		"generate:types": "node scripts/generate-types.js",
		"lint": "npm run eslint",
		"release": "changeset publish"
	}
}
